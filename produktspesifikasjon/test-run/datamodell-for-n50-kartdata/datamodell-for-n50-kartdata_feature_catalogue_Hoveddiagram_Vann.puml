@startuml
' For wide diagrams, render with: plantuml -DPLANTUML_LIMIT_SIZE=16384 ...
' The 'scale max' directive below caps the rendered output to prevent the
' default PlantUML 4096px size limit from cropping the diagram.
scale max 4000*4000

title N50 Kartdata - Datamodell for N50 kartdata - Hoveddiagram Vann

skinparam backgroundColor #F5F5F5
skinparam shadowing false
skinparam RoundCorner 6
skinparam ArrowColor #6C8198
skinparam wrapWidth 200
skinparam class {
  BackgroundColor #FBF2E8
  BorderColor #9C8578
  FontColor #2D201A
  HeaderBackgroundColor #EFE1D6
  HeaderFontColor #2D201A
  AttributeIconSize 0
}
skinparam note {
  BackgroundColor #FFFFFF
  BorderColor #6C8198
  FontColor #2D201A
}
skinparam stereotypeCBackgroundColor #EAD9CE
skinparam stereotypeCBorderColor #9C8578
skinparam stereotypeCFontColor #2D201A

abstract class SOSI_Objekt_Flater <<featureType>> {
  + oppdateringsdato [1] : Date
}

abstract class SOSI_Objekt_Sperrelinjer <<featureType>> {
  + oppdateringsdato [1] : Date
}

abstract class SOSI_Objekt_Kombinasjon_Ulike_Geometrityper <<featureType>> {
  + datafangstdato [0..1] : Date
  + oppdateringsdato [1] : Date
  + kvalitet [0..1] : Posisjonskvalitet
}

class KantUtsnitt <<featureType>> {
  + grense [1] : GM_Curve
}

abstract class SOSI_Objekt_PunkterOgLinjer <<featureType>> {
  + datafangstdato [1] : Date
  + oppdateringsdato [1] : Date
  + kvalitet [1] : Posisjonskvalitet
}

class ElvMidtlinje <<featureType>> {
  + senterlinje [1] : GM_Curve
}

class "Flomløpkant" as Floml_pkant <<featureType>> {
  + grense [1] : GM_Curve
}

class ElvelinjeFiktiv <<featureType>> {
  + senterlinje [1] : GM_Curve
}

class ElveKant <<featureType>> {
  + grense [1] : GM_Curve
}

class "InnsjøInnsjøSperre" as Innsj_Innsj_Sperre <<featureType>> {
  + grense [1] : GM_Curve
}

class Kystkontur <<featureType>> {
  + grense [1] : GM_Curve
}

class "FerskvannTørrfall" as FerskvannT_rrfall <<featureType>> {
  + område [1] : GM_Surface
}

class "KanalGrøft" as KanalGr_ft <<featureType>> {
  + senterlinje [1] : GM_Curve
  + vannBredde [1] : VannBredde
}

class ElvBekk <<featureType>> {
  + senterlinje [1] : GM_Curve
  + vannbredde [1] : VannBredde
}

class "FerskvannTørrfallkant" as FerskvannT_rrfallkant <<featureType>> {
  + grense [1] : GM_Curve
}

class "Innsjøkant" as Innsj_kant <<featureType>> {
  + grense [1] : GM_Curve
}

class "HavInnsjøSperre" as HavInnsj_Sperre <<featureType>> {
  + grense [1] : GM_Curve
}

class HavElvSperre <<featureType>> {
  + grense [1] : GM_Curve
}

class "Innsjø" as Innsj_ <<featureType>> {
  + område [1] : GM_Surface
  + vatnLøpenummer [0..1] : Integer
  + høyde [0..1] : Integer
}

class "InnsjøMidtlinje" as Innsj_Midtlinje <<featureType>> {
  + senterlinje [1] : GM_Curve
}

class Havflate <<featureType>> {
  + område [1] : GM_Surface
}

class "InnsjøRegulert" as Innsj_Regulert <<featureType>> {
  + område [0..1] : GM_Surface
  + vatnLøpenummer [0..1] : Integer
  + lavesteRegulerteVannstand [0..1] : Integer
  + høyde [0..1] : Integer
}

class Elv <<featureType>> {
  + område [1] : GM_Surface
}

class "Skjær" as Skj_r <<featureType>> {
  + posisjon [1] : GM_Point
}

class "InnsjøkantRegulert" as Innsj_kantRegulert <<featureType>> {
  + grense [1] : GM_Curve
}

class "InnsjøElvSperre" as Innsj_ElvSperre <<featureType>> {
  + grense [1] : GM_Curve
}

class Posisjonskvalitet <<dataType>> {
  + målemetode [1] : Målemetode
  + nøyaktighet [1] : Nøyaktighet
}

package "Eksterne referanser" <<Frame>> {
  class Dataavgrensning <<Hoveddiagram Generelle typer>> {
  }
  class FiktivDelelinje <<Hoveddiagram Generelle typer>> {
  }
  class SOSI_Objekt_Hjelpelinjer <<Hoveddiagram Generelle typer>> {
  }
}

SOSI_Objekt_Flater --> KantUtsnitt : avgrensesAvKantutsnitt [0..*]
SOSI_Objekt_Kombinasjon_Ulike_Geometrityper --> KantUtsnitt : avgrensesAvKantUtsnitt [0..*]
SOSI_Objekt_Hjelpelinjer <|-- KantUtsnitt
SOSI_Objekt_PunkterOgLinjer <|-- ElvMidtlinje
SOSI_Objekt_PunkterOgLinjer <|-- Floml_pkant
SOSI_Objekt_PunkterOgLinjer <|-- ElvelinjeFiktiv
SOSI_Objekt_PunkterOgLinjer <|-- ElveKant
SOSI_Objekt_Sperrelinjer <|-- Innsj_Innsj_Sperre
SOSI_Objekt_PunkterOgLinjer <|-- Kystkontur
SOSI_Objekt_Flater <|-- FerskvannT_rrfall
FerskvannT_rrfall --> ElveKant : avgrensesAvElveKant [0..*]
FerskvannT_rrfall --> FerskvannT_rrfallkant : avgrensesAvFerskvanntørrfallkant [0..*]
SOSI_Objekt_PunkterOgLinjer <|-- KanalGr_ft
SOSI_Objekt_PunkterOgLinjer <|-- ElvBekk
SOSI_Objekt_PunkterOgLinjer <|-- FerskvannT_rrfallkant
SOSI_Objekt_PunkterOgLinjer <|-- Innsj_kant
SOSI_Objekt_Sperrelinjer <|-- HavInnsj_Sperre
SOSI_Objekt_Sperrelinjer <|-- HavElvSperre
SOSI_Objekt_Flater <|-- Innsj_
Innsj_ --> FiktivDelelinje : avgrensesAvFiktivdelelinje [0..*]
Innsj_ --> Dataavgrensning : avgrensesAvDataavgrensning [0..*]
Innsj_ --> Innsj_Innsj_Sperre : avgrensesAvInnsjøinnsjøsperre [0..*]
Innsj_ --> Innsj_kant : avgrensesAvInnsjøkant [0..*]
Innsj_ --> HavInnsj_Sperre : avgrensesAvHavInnsjøSperre [0..*]
Innsj_ --> Innsj_ElvSperre : avgrensesAvInnsjøElvSperre [0..*]
SOSI_Objekt_PunkterOgLinjer <|-- Innsj_Midtlinje
SOSI_Objekt_Flater <|-- Havflate
Havflate --> FiktivDelelinje : avgrensesAvFiktivdelelinje [0..*]
Havflate --> Dataavgrensning : avgrensesAvDataavgrensning [0..*]
Havflate --> Kystkontur : avgrensesAvKystkontur [0..*]
Havflate --> HavInnsj_Sperre : avgrensesAvHavInnsjøSperre [0..*]
Havflate --> HavElvSperre : avgrensesAvHavElvSperre [0..*]
SOSI_Objekt_Flater <|-- Innsj_Regulert
Innsj_Regulert --> FiktivDelelinje : avgrensesAvFiktivdelelinje [0..*]
Innsj_Regulert --> Dataavgrensning : avgrensesAvDataavgrensning [0..*]
Innsj_Regulert --> Innsj_Innsj_Sperre : avgrensesAvInnsjøinnsjøsperre [0..*]
Innsj_Regulert --> Innsj_ElvSperre : avgrensesAvInnsjøElvSperre [0..*]
Innsj_Regulert --> Innsj_kantRegulert : avgrensesAvInnsjøkantregulert [0..*]
SOSI_Objekt_Flater <|-- Elv
Elv --> FiktivDelelinje : avgrensesAvFiktivdelelinje [0..*]
Elv --> Dataavgrensning : avgrensesAvDataavgrensning [0..*]
Elv --> ElveKant : avgrensesAvElveKant [0..*]
Elv --> FerskvannT_rrfallkant : avgrensesAvFerskvanntørrfallkant [0..*]
Elv --> HavElvSperre : avgrensesAvHavElvSperre [0..*]
Elv --> Innsj_ElvSperre : avgrensesAvInnsjøElvSperre [0..*]
SOSI_Objekt_PunkterOgLinjer <|-- Skj_r
SOSI_Objekt_PunkterOgLinjer <|-- Innsj_kantRegulert
SOSI_Objekt_Sperrelinjer <|-- Innsj_ElvSperre

@enduml
